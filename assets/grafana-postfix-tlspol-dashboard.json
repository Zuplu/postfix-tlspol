      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(increase(postfix_tlspol_queries_total{instance=~\"${instance:regex}\"}[$__range]))",
          "legendFormat": "Total Queries",
          "range": true,
          "refId": "A"
