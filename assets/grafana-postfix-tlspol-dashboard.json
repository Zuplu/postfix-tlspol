    {
      "id": 11,
      "title": "Cache Hit Ratio",
      "description": "Percentage of policy cache lookups served without a network policy refresh.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * (sum(rate(postfix_tlspol_cache_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",result=\"hit\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(postfix_tlspol_cache_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\"}[$__rate_interval])) or vector(0), 1e-9)",
          "legendFormat": "Hit Ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 70,
                "color": "orange"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
