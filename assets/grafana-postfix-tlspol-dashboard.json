      "title": "Oldest Sample Age",
      "description": "Age of the stalest selected postfix-tlspol sample. Sustained growth indicates a scrape or target failure.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(time() - timestamp(postfix_tlspol_queries_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\"}))",
          "legendFormat": "Sample Age",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 45,
                "color": "orange"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
